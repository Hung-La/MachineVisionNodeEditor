<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:NodeViewModels="clr-namespace:MachineVisionNodeEditor.ViewModels.NodeViewModels"
                    xmlns:NodeView="clr-namespace:MachineVisionNodeEditor.Views.Nodes"
                    xmlns:ImageImportNodeView="clr-namespace:MachineVisionNodeEditor.Views.Nodes.ImageImport"
                    xmlns:ImageImportNodeViewModel="clr-namespace:MachineVisionNodeEditor.ViewModels.NodeViewModels.ImageImport_NodeViewModels">

    <DataTemplate DataType="{x:Type NodeViewModels:Node_NodeViewModel}">
        <NodeView:Node_NodeView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type ImageImportNodeViewModel:ImageImport_NodeViewModel}">
        <ImageImportNodeView:ImageImport_NodeView/>
    </DataTemplate>

</ResourceDictionary>