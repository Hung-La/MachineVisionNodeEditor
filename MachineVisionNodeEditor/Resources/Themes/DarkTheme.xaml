<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush Color="#1c1b21" x:Key="Backdrop"></SolidColorBrush>
    <SolidColorBrush Color="WhiteSmoke" x:Key="Text"></SolidColorBrush>
    <SolidColorBrush Color="#353b48" x:Key="Card"></SolidColorBrush>
    <SolidColorBrush Color="#FFECEFF1" x:Key="Grid"></SolidColorBrush>

    <SolidColorBrush Color="#FFEB3B" x:Key="PathData"></SolidColorBrush>
    <SolidColorBrush Color="#FFECEFF1" x:Key="NodeBackground"></SolidColorBrush>
    <SolidColorBrush Color="LightSkyBlue" x:Key="CoordinateText"></SolidColorBrush>

    <SolidColorBrush Color="SkyBlue" x:Key="ConnectionColor"></SolidColorBrush>

    <SolidColorBrush x:Key="ColorIconsMain"  Color="#FF455A64"/>
    <SolidColorBrush x:Key="ColorIconsSecond"  Color="#7ac0ff"/>
    <SolidColorBrush x:Key="ColorIconsThird"  Color="#FF69F0AE"/>
    <SolidColorBrush x:Key="ColorIconsFourth"  Color="#FFFF9100"/>

    <SolidColorBrush Color="#FF37474F" x:Key="WindowBackground"></SolidColorBrush>
    
    <!--#region Menu Item-->
    <SolidColorBrush x:Key="MenuItemBackground" Color="#2d2d30"/>
    <SolidColorBrush x:Key="MenuItemHoverBackground" Color="#3e3e42"/>
    <SolidColorBrush x:Key="MenuItemBorder" Color="#007acc"/>
    <SolidColorBrush x:Key="MenuItemForeground" Color="White"/>
    <!--#endregion-->
    
</ResourceDictionary>