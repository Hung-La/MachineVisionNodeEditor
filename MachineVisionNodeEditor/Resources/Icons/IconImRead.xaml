<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconImread">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- 📄 Khung ảnh -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsMain}"
                    Geometry="M2,2 L12,2 L12,12 L2,12 Z" />

                <!-- 🖼️ Nền ảnh -->
                <GeometryDrawing
                    Brush="White"
                    Geometry="M3,3 L11,3 L11,11 L3,11 Z" />

                <!-- ⛰️ Núi -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsThird}"
                    Geometry="M4,10 L6.5,7 L8,8.5 L10,6 L10.5,10 Z" />

                <!-- ☀️ Mặt trời -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsFourth}"
                    Geometry="M8.8,4.8 A0.8,0.8 0 1 1 8.7,4.8 Z" />

                <!-- ➜ Mũi tên đọc vào -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M13,6 L13,5 L16,7 L13,9 L13,8 L10,8 L10,6 Z" />

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>