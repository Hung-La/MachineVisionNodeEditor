<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconImwrite">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- 🖼️ Khung ảnh -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsMain}"
                    Geometry="M2,2 L10,2 L10,10 L2,10 Z" />

                <!-- 📄 Nền ảnh -->
                <GeometryDrawing
                    Brush="White"
                    Geometry="M3,3 L9,3 L9,9 L3,9 Z" />

                <!-- ⛰️ Núi -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsThird}"
                    Geometry="M4,8 L5.5,6 L6.8,7 L8,5.5 L8.5,8 Z" />

                <!-- ☀️ Mặt trời -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsFourth}"
                    Geometry="M7.2,4.2 A0.6,0.6 0 1 1 7.1,4.2 Z" />

                <!-- ➜ Mũi tên ghi ra -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M10,5 L13,5 L13,4 L16,6 L13,8 L13,7 L10,7 Z" />

                <!-- 💾 Disk save -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsMain}"
                    Geometry="M16,3 L20,3 L20,9 L16,9 Z" />

                <!-- 💾 Ô trắng -->
                <GeometryDrawing
                    Brush="White"
                    Geometry="M17,4 L19,4 L19,6 L17,6 Z" />

                <!-- 💾 Thanh dưới -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsThird}"
                    Geometry="M17,7 L19,7 L19,8 L17,8 Z" />

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>