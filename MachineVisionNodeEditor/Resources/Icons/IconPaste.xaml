<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconPaste">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- Clipboard -->
                <GeometryDrawing
                Brush="#E0E0E0"
                Geometry="M5,3 L11,3 L11,14 L5,14 Z" />

                <!-- Clip -->
                <GeometryDrawing
                Brush="#B0B0B0"
                Geometry="M6,1 L10,1 L10,3 L6,3 Z" />

                <!-- Paper -->
                <GeometryDrawing
                Brush="{DynamicResource ColorIconsMain}"
                Geometry="M7,6 L12,6 L14,8 L14,15 L7,15 Z" />

                <!-- Fold -->
                <GeometryDrawing
                Brush="#CCCCCC"
                Geometry="M12,6 L14,8 L12,8 Z" />

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>