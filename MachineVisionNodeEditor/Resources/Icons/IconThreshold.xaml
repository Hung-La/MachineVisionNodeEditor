<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconThreshold">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- Frame -->
                <GeometryDrawing
                Brush="{DynamicResource ColorIconsMain}"
                Geometry="M2,3 L14,3 L14,13 L2,13 Z"/>

                <!-- Gradient background -->
                <GeometryDrawing Geometry="M3,4 L13,4 L13,12 L3,12 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Black" Offset="0"/>
                            <GradientStop Color="White" Offset="1"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- Threshold split -->
                <GeometryDrawing
                Brush="White"
                Geometry="M8,4 L13,4 L13,12 L8,12 Z"/>

                <!-- Line -->
                <GeometryDrawing
                Brush="#FF3D00"
                Geometry="M8,4 L8,12"/>

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>