<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconGaussianBlur">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- 🖼️ Frame -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsMain}"
                    Geometry="M2,3 L14,3 L14,13 L2,13 Z"/>

                <!-- 🌫️ Gaussian blur background -->
                <GeometryDrawing Geometry="M5,6 A2,2 0 1 1 4.9,6 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#D8D8D8" Offset="0.4"/>
                            <GradientStop Color="#888888" Offset="1"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- 🌫️ Outer blur -->
                <GeometryDrawing Geometry="M7,8 A3.2,3.2 0 1 1 6.9,8 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="#BBBBBB" Offset="0"/>
                            <GradientStop Color="#777777" Offset="0.7"/>
                            <GradientStop Color="#444444" Offset="1"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- 📈 Gaussian curve -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="
                        M3,11
                        C5,11 5.5,5 8,5
                        C10.5,5 11,11 13,11
                        L13,12
                        C10,12 9.5,7 8,7
                        C6.5,7 6,12 3,12 Z"/>

                <!-- ✨ Gaussian center point -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsFourth}"
                    Geometry="M8,7 A0.6,0.6 0 1 1 7.9,7 Z"/>

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>