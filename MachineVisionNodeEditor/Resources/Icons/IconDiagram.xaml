<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconDiagram">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- Lines -->
                <GeometryDrawing Brush="{DynamicResource ColorIconsMain}" Geometry="M4,6 L10,6"/>
                <GeometryDrawing Brush="{DynamicResource ColorIconsMain}" Geometry="M10,6 L12,10"/>

                <!-- Node vuông -->
                <GeometryDrawing Brush="{DynamicResource ColorIconsMain}" Geometry="M3,5 L5,5 L5,7 L3,7 Z"/>

                <!-- Node tròn -->
                <GeometryDrawing Brush="{DynamicResource ColorIconsMain}" Geometry="M10,6 A1,1 0 1 1 9.9,6 Z"/>

                <!-- Node vuông -->
                <GeometryDrawing Brush="{DynamicResource ColorIconsMain}" Geometry="M11,9 L13,9 L13,11 L11,11 Z"/>

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>