<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconImshow">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- 🖥️ Khung màn hình -->
                <GeometryDrawing
                Brush="{DynamicResource ColorIconsMain}"
                Geometry="M2,3 L14,3 L14,11 L2,11 Z" />

                <!-- 📺 Chân màn -->
                <GeometryDrawing
                Brush="{DynamicResource ColorIconsMain}"
                Geometry="M6,11 L10,11 L10,13 L6,13 Z" />

                <!-- 🖼️ Nội dung ảnh (nền trắng) -->
                <GeometryDrawing
                Brush="White"
                Geometry="M3,4 L13,4 L13,10 L3,10 Z" />

                <!-- ⛰️ Hình ảnh bên trong (núi) -->
                <GeometryDrawing
                Brush="{DynamicResource ColorIconsThird}"
                Geometry="M4,9 L7,6 L9,8 L11,5 L12,9 Z" />

                <!-- ☀️ Mặt trời -->
                <GeometryDrawing
                Brush="{DynamicResource ColorIconsFourth}"
                Geometry="M10,5 A1,1 0 1 1 9.9,5 Z" />

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>