<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconResize">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- 🖼️ Main image -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsMain}"
                    Geometry="M4,4 L16,4 L16,16 L4,16 Z"/>

                <!-- 📄 Inner background -->
                <GeometryDrawing
                    Brush="White"
                    Geometry="M5,5 L15,5 L15,15 L5,15 Z"/>

                <!-- ⛰️ Landscape -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsThird}"
                    Geometry="M6,13 L9,9 L11,11 L14,7 L14.5,13 Z"/>

                <!-- ☀️ Sun -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsFourth}"
                    Geometry="M12,7 A0.8,0.8 0 1 1 11.9,7 Z"/>

                <!-- ↔ Horizontal resize -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="
                        M1,10
                        L4,8
                        L4,9
                        L7,9
                        L7,11
                        L4,11
                        L4,12 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="
                        M19,10
                        L16,8
                        L16,9
                        L13,9
                        L13,11
                        L16,11
                        L16,12 Z"/>

                <!-- ↕ Vertical resize -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="
                        M10,1
                        L8,4
                        L9,4
                        L9,7
                        L11,7
                        L11,4
                        L12,4 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="
                        M10,19
                        L8,16
                        L9,16
                        L9,13
                        L11,13
                        L11,16
                        L12,16 Z"/>

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>