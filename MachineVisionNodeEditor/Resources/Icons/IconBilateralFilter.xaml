<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconBilateralFilter">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- 🖼️ Frame -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsMain}"
                    Geometry="M2,3 L14,3 L14,13 L2,13 Z"/>

                <!-- 🌫️ Smooth blur region -->
                <GeometryDrawing Geometry="M5,8 A3,3 0 1 1 4.9,8 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#CCCCCC" Offset="0.5"/>
                            <GradientStop Color="#666666" Offset="1"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- ⚫ Sharp edge preservation -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M8,3 L9,3 L9,13 L8,13 Z"/>

                <!-- ✨ Left smooth side -->
                <GeometryDrawing
                    Brush="#55FFFFFF"
                    Geometry="M3,4 L8,4 L8,12 L3,12 Z"/>

                <!-- 🔳 Right detail side -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsThird}"
                    Geometry="M10,5 L12,5 L12,7 L10,7 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsThird}"
                    Geometry="M10,8 L11,8 L11,9 L10,9 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsFourth}"
                    Geometry="M11,10 L12,10 L12,11 L11,11 Z"/>

                <!-- 📡 Bilateral connection -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsFourth}"
                    Geometry="
                        M5,8
                        C6,6 7,5 8.5,5
                        L8.5,6
                        C7.5,6 6.5,7 6,8
                        C6.5,9 7.5,10 8.5,10
                        L8.5,11
                        C7,11 6,10 5,8 Z"/>

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>