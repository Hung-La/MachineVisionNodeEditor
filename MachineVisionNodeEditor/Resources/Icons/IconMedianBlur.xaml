<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DrawingImage x:Key="IconMedianBlur">
        <DrawingImage.Drawing>
            <DrawingGroup>

                <!-- 🖼️ Frame -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsMain}"
                    Geometry="M2,3 L14,3 L14,13 L2,13 Z"/>

                <!-- 🌫️ Soft blur background -->
                <GeometryDrawing Geometry="M5,6 A2.2,2.2 0 1 1 4.9,6 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#CFCFCF" Offset="0.5"/>
                            <GradientStop Color="#777777" Offset="1"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- 🌫️ Outer blur -->
                <GeometryDrawing Geometry="M7,8 A3.3,3.3 0 1 1 6.9,8 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="#BEBEBE" Offset="0"/>
                            <GradientStop Color="#666666" Offset="1"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>

                <!-- 🔲 Median kernel pixels -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M5,5 L6,5 L6,6 L5,6 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M7,5 L8,5 L8,6 L7,6 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M9,5 L10,5 L10,6 L9,6 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M5,7 L6,7 L6,8 L5,8 Z"/>

                <!-- ⭐ Median center -->
                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsFourth}"
                    Geometry="M7,7 L8,7 L8,8 L7,8 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M9,7 L10,7 L10,8 L9,8 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M5,9 L6,9 L6,10 L5,10 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M7,9 L8,9 L8,10 L7,10 Z"/>

                <GeometryDrawing
                    Brush="{DynamicResource ColorIconsSecond}"
                    Geometry="M9,9 L10,9 L10,10 L9,10 Z"/>

            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>