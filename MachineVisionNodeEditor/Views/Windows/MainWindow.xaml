<Window x:Class="MachineVisionNodeEditor.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MachineVisionNodeEditor"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:i="clr-namespace:Microsoft.Xaml.Behaviors;assembly=Microsoft.Xaml.Behaviors"
        xmlns:UserControl="clr-namespace:MachineVisionNodeEditor.Views.UserControls"
        xmlns:ToggleButton="clr-namespace:HungLaToggleButtonLib;assembly=HungLaToggleButtonLib"
        xmlns:WindowViewModel="clr-namespace:MachineVisionNodeEditor.ViewModels.WindowViewModels"
        xmlns:NodeViewModel="clr-namespace:MachineVisionNodeEditor.ViewModels.NodeViewModels"
        xmlns:Node="clr-namespace:MachineVisionNodeEditor.Views.Nodes"
        xmlns:ImageImportNode="clr-namespace:MachineVisionNodeEditor.Views.Nodes.ImageImport"
        WindowStyle="None"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource WindowBackground}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        mc:Ignorable="d"
        Name="mainWindow"
        d:DataContext="{d:DesignInstance Type=WindowViewModel:Window_MainWindowViewModel}"
        Title="Machine Vision Diagram Editor" Height="600" Width="900">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--<ResourceDictionary Source="/Resources/MainResource.xaml"></ResourceDictionary>-->
                <ResourceDictionary Source="/Resources/Styles/WindowStyle.xaml"></ResourceDictionary>
                
                <ResourceDictionary Source="/Resources/DataTemplates/WindowDataTemplate.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Window.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedWindowCommand}" CommandParameter="{Binding ElementName=mainWindow}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>

        <UserControl:UserControl_ControlBar
            Grid.Row="0"
            Tag="{Binding ElementName=mainWindow, Path=Title}">

        </UserControl:UserControl_ControlBar>

        <DockPanel 
            Grid.Row="1">
            <Menu
                ItemContainerStyle="{StaticResource MenuItemStyle}"
                DockPanel.Dock="Left">

                <MenuItem Header="File">
                    <MenuItem Header="New"></MenuItem>
                    <MenuItem Header="Open"></MenuItem>
                    <MenuItem Header="Exit"></MenuItem>
                </MenuItem>

                <MenuItem Header="Edit">
                    <MenuItem Header="Copy"></MenuItem>
                    <MenuItem Header="Paste"></MenuItem>
                </MenuItem>
            </Menu>

            <Canvas
                DockPanel.Dock="Right">
                <ToggleButton:CustomToggleButton
                    Canvas.Right="10"
                    VerticalContentAlignment="Center"
                    Margin="5 10"
                    IsChecked="{Binding IsChecked_ToggleTheme}"
                    ToolTip="Theme: Light - Dark"
                    OffThumbColor="DarkSlateGray"
                    OnThumbColor="WhiteSmoke"
                    OffBackground="#FFEEEEEE"
                    OnBackground="gray">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <i:InvokeCommandAction Command="{Binding ChangeTheme}" 
                                                   CommandParameter="{Binding ElementName=mainWindow}">
                            </i:InvokeCommandAction>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ToggleButton:CustomToggleButton>
            </Canvas>

        </DockPanel>

        <Border 
            Grid.Row="2"
            BorderThickness="2"
            BorderBrush="SkyBlue"
            Margin="2">

            <!-- Lật toàn bộ Ribbon -->
            <Border.LayoutTransform>
                <ScaleTransform ScaleY="-1"/>
            </Border.LayoutTransform>

            <Ribbon 
                ShowQuickAccessToolBarOnTop="False"
                Margin="0" Padding="2"
                Height="auto">

                <Ribbon.ApplicationMenu>
                    <RibbonApplicationMenu Visibility="Collapsed" />
                </Ribbon.ApplicationMenu>

                <!-- Lật ngược nội dung bên trong lại cho đúng chiều -->
                <Ribbon.Resources>
                    <Style TargetType="RibbonGroup">

                        <Setter Property="LayoutTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleY="-1"/>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style TargetType="RibbonTabHeader">
                        <Setter Property="Height" Value="20"/>
                        <Setter Property="Padding" Value="6,2"/>
                        <Setter Property="LayoutTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleY="-1"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Ribbon.Resources>

                <RibbonTab
                    Header="Home">

                    <RibbonGroup
                        Header="File">

                        <RibbonButton 
                            Label="New"
                            LargeImageSource="{StaticResource IconNewScheme}">
                        </RibbonButton>

                        <RibbonButton 
                            Label="Open"
                            LargeImageSource="{StaticResource IconOpenScheme}">
                        </RibbonButton>

                        <RibbonButton
                            Label="Save"
                            LargeImageSource="{StaticResource IconSave}">
                        </RibbonButton>

                        <RibbonButton
                            Label="Save As"
                            LargeImageSource="{StaticResource IconSaveAs}">
                        </RibbonButton>

                    </RibbonGroup>

                    <RibbonGroup
                        Header="Edit">

                        <RibbonButton
                            Label="Undo"
                            LargeImageSource="{StaticResource IconUndo}">
                        </RibbonButton>

                        <RibbonButton
                            Label="Redo"
                            LargeImageSource="{StaticResource IconRedo}">
                        </RibbonButton>

                        <RibbonButton
                            Label="Copy"
                            LargeImageSource="{StaticResource IconCopy}">
                        </RibbonButton>

                        <RibbonButton
                            Label="Cut"
                            LargeImageSource="{StaticResource IconCut}">
                        </RibbonButton>

                        <RibbonButton
                            Label="Paste"
                            LargeImageSource="{StaticResource IconPaste}">
                        </RibbonButton>

                    </RibbonGroup>

                </RibbonTab>

                <RibbonTab
                    Header="Image Interaction">

                    <RibbonGroup
                        Header="Image Operation">
                        <RibbonButton
                            x:Name="RibbonButton_ImageImport"
                            Label="Image Import"
                            LargeImageSource="{StaticResource IconImread}"
                            Click="RibbonButton_ImageImport_Click">
                        </RibbonButton>

                        <RibbonButton 
                            x:Name="RibbonButton_ImageShow"
                            Label="Image Show"
                            LargeImageSource="{StaticResource IconImshow}">
                        </RibbonButton>

                        <RibbonButton 
                            x:Name="RibbonButton_ImageExport"
                            Label="Image Output"
                            LargeImageSource="{StaticResource IconImwrite}">
                        </RibbonButton>

                        <RibbonButton 
                            x:Name="RibbonButton_Test"
                            Label="Image Test"
                            LargeImageSource="{StaticResource IconTest}"
                            Click="RibbonButton_Test_Click">
                        </RibbonButton>
                    </RibbonGroup>

                    <RibbonGroup
                        Header="Image Transformation">
                        <RibbonButton 
                            x:Name="RibbonButton_ImageResize"
                            Label="Image Resize"
                            LargeImageSource="{StaticResource IconResize}">
                        </RibbonButton>

                        <RibbonButton 
                            x:Name="RibbonButton_ImageRotate"
                            Label="Image Rotate"
                            LargeImageSource="{StaticResource IconRotate}">
                        </RibbonButton>

                    </RibbonGroup>

                </RibbonTab>

                <RibbonTab
                    Header="Pre-Processing">

                    <RibbonGroup
                        Header="Image - Filter">

                        <!--<RibbonButton 
                            Label="Blur Filter"
                            LargeImageSource="{StaticResource IconBlur}">
                        </RibbonButton>-->

                        <RibbonButton 
                            Label="Gaussian Blur Filter"
                            LargeImageSource="{StaticResource IconGaussianBlur}">
                        </RibbonButton>

                        <RibbonButton 
                            Label="Median Blur Filter"
                            LargeImageSource="{StaticResource IconMedianBlur}">
                        </RibbonButton>

                        <RibbonButton 
                            Label="Bilateral Blur Filter"
                            LargeImageSource="{StaticResource IconBilateralFilter}">
                        </RibbonButton>

                    </RibbonGroup>

                    <RibbonGroup
                        Header="Pre-Processing">

                        <RibbonButton 
                            Label="Grayscale"
                            LargeImageSource="{StaticResource IconGrayscale}">
                        </RibbonButton>

                        <RibbonButton 
                            Label="Threshold"
                            LargeImageSource="{StaticResource IconThreshold}">
                        </RibbonButton>
                    </RibbonGroup>

                </RibbonTab>
                
            </Ribbon>

        </Border>

        <GroupBox
            Grid.Row="3"
            Style="{StaticResource Style for GroupBox}">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icon -->
                    <Image 
                        Source="{StaticResource IconDiagram}" 
                        Width="16" Height="16"
                        Margin="0,0,6,0"/>
                    <TextBlock 
                        Text="Designed Diagram" FontSize="14"
                        Foreground="{DynamicResource Text}">
                    </TextBlock>
                </StackPanel>
            </GroupBox.Header>

            <Canvas 
                Grid.Row="0"
                x:Name="MainCanvas"
                MouseUp="MainCanvas_MouseUp"
                MouseMove="MainCanvas_MouseMove">

                <Canvas.Background>
                    <DrawingBrush 
                        TileMode="Tile"
                        Viewport="0,0,100,100"
                        ViewportUnits="Absolute">

                        <DrawingBrush.Drawing>
                            <DrawingGroup>

                                <!-- 🎨 MÀU NỀN -->
                                <GeometryDrawing Brush="Transparent">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,100,100"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>

                                <!-- 🔲 GRID -->
                                <GeometryDrawing Brush="Transparent">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="{DynamicResource Grid}" Thickness="0.7">
                                            <Pen.DashStyle>
                                                <DashStyle Dashes="2.5"/>
                                            </Pen.DashStyle>
                                        </Pen>
                                    </GeometryDrawing.Pen>

                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <!-- dọc -->
                                            <LineGeometry StartPoint="0,0" EndPoint="0,100"/>
                                            <!-- ngang -->
                                            <LineGeometry StartPoint="0,0" EndPoint="100,0"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>

                            </DrawingGroup>
                        </DrawingBrush.Drawing>

                    </DrawingBrush>
                </Canvas.Background>

                 <!--CONNECTION--> 
                <ItemsControl 
                    x:Name="ConnectionsControl"
                    ItemsSource="{Binding Connections, UpdateSourceTrigger=PropertyChanged}"
                    Panel.ZIndex="0">

                     <!--🔥 QUAN TRỌNG: dùng Canvas--> 
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                     <!--🔥 ép tất cả Path về (0,0)--> 
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left" Value="0"/>
                            <Setter Property="Canvas.Top" Value="0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Path 
                                Stroke="{DynamicResource ConnectionColor}"
                                StrokeThickness="3"
                                SnapsToDevicePixels="True"
                                IsHitTestVisible="False">

                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="{Binding ConnectionModel.Start}">
                                            <BezierSegment 
                                                Point1="{Binding ConnectionModel.Control1}"
                                                Point2="{Binding ConnectionModel.Control2}"
                                                Point3="{Binding ConnectionModel.End}"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>

                            </Path>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                 <!--NODE--> 
                <ItemsControl 
                    x:Name="NodesControl"
                    ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left" Value="{Binding NodeModel.X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding NodeModel.Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <!--<ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Node:NodeControl>
                                <Node:NodeControl.DataContext>
                                    <NodeViewModel:Node_NodeViewModel></NodeViewModel:Node_NodeViewModel>
                                </Node:NodeControl.DataContext>
                            </Node:NodeControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>-->

                </ItemsControl>

                <!--<ItemsControl 
                    x:Name="NodesControl_ImageImport"
                    ItemsSource="{Binding ImageImportNodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left" Value="{Binding NodeModel.X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding NodeModel.Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ImageImportNode:ImageImport_NodeView/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>-->

                <!--── Preview khi đang kéo dây ──────────────────────-->
                <Path x:Name="PreviewPath"
                          Stroke="{DynamicResource PathData}"
                          StrokeThickness="2"
                          StrokeDashArray="6 3"
                          IsHitTestVisible="False"/>

                <Rectangle 
                    x:Name="SelectionBox"
                    Stroke="DodgerBlue"
                    StrokeThickness="1"
                    Fill="#22007ACC"
                    Visibility="Collapsed"/>

                <TextBlock
                    x:Name="TextBlock_CursorCoordinate"
                    Canvas.Bottom="3"
                    Canvas.Right="3"
                    Grid.Row="4"
                    Height="25"
                    Foreground="{DynamicResource CoordinateText}"
                    Background="{DynamicResource WindowBackground}"
                    FontSize="20"
                    FontStyle="Normal"
                    Margin="3"
                    Padding="3">

                </TextBlock>

            </Canvas>

        </GroupBox>


    </Grid>
    
</Window>
