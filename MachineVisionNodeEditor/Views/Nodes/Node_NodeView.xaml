<local:NodeControl
            x:Class="MachineVisionNodeEditor.Views.Nodes.Node_NodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MachineVisionNodeEditor.Views.Nodes"
             xmlns:ViewModel="clr-namespace:MachineVisionNodeEditor.ViewModels.NodeViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=ViewModel:Node_NodeViewModel}"
             d:DesignHeight="150" d:DesignWidth="160"
             Loaded="NodeControl_Loaded">

    <local:NodeControl.Resources>
        <!--<ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source=""></ResourceDictionary>
        </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>-->

        <!-- Style cho port (hình tròn nhỏ) -->
        <Style x:Key="PortStyle" TargetType="Ellipse">
            <Setter Property="Width"  Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Fill"   Value="#37474F"/>
            <Setter Property="Stroke" Value="#00BCD4"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Cursor" Value="Cross"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#00BCD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </local:NodeControl.Resources>

    <!-- Shadow effect cho node -->
    <local:NodeControl.Effect>
        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.5"/>
    </local:NodeControl.Effect>

    <!--<UserControl.DataContext>
        <ViewModel:Node_NodeViewModel></ViewModel:Node_NodeViewModel>
    </UserControl.DataContext>-->

    <Grid>
        <!-- Body của node -->
        <Border Background="{DynamicResource NodeBackground}"
            BorderBrush="#455A64"
            BorderThickness="1.5"
            CornerRadius="8"
            Padding="0,0,0,12"
            MouseDown="Header_MouseDown"
            MouseMove="Header_MouseMove"
            MouseUp="Header_MouseUp">
            <StackPanel 
                x:Name="StackPanel_Text">
                <!-- Header -->
                <Border Background="#00BCD4"
                    CornerRadius="6,6,0,0"
                    Padding="10,6"
                    Cursor="SizeAll">
                    <TextBlock 
                        x:Name="TextBlock_Header"
                        Text="{Binding NodeModel.Title}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="13"
                        FontFamily="Consolas"/>
                </Border>

                <!-- Content -->
                <Grid 
                    x:Name="Grid_Node"
                    Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- INPUT PORTS (left, dynamic) -->
                    <ItemsControl Grid.Column="0"
                                  x:Name="InputPortsControl"
                                  ItemsSource="{Binding NodeModel.InputPorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- DataContext here IS the PortModel -->
                                <local:Node_PortView
                                Margin="-10,2,0,2"
                                PortMouseUp="Port_PortMouseUp"
                                ToolTip="Input Port"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Label -->
                    <TextBlock Grid.Column="1"
                           Text="{Binding NodeModel.Description}"
                           Foreground="#546E7A"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                    <!-- OUTPUT PORTS (right, dynamic) -->
                    <ItemsControl Grid.Column="2"
                                  x:Name="OutputPortsControl"
                                  ItemsSource="{Binding NodeModel.OutputPorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:Node_PortView
                                    Margin="0,2,-10,2"
                                    PortMouseUp="Port_PortMouseUp"
                                    ToolTip="Output Port"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

            </StackPanel>

        </Border>

    </Grid>

</local:NodeControl>
